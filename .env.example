# Скопируйте в .env: cp .env.example .env
# Docker Compose подставляет эти переменные в docker-compose*.yml

# --- Telegram (обязательно, если API_ONLY не true) ---
BOT_TOKEN=

# --- токен Яндекс Формы
YANDEX_FORMS_WEBHOOK_TOKEN=

# --- Пароль для Grafana ---
GRAFANA_ADMIN_PASSWORD=admin  # Смените на production

# Только API + метрики, без Telegram-бота (локальная разработка фронта и т.п.)
API_ONLY=false

# --- БД (совпадают с postgres в compose) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# --- Redis ---
REDIS_PASSWORD=redis
REDIS_DB=0

# --- HTTP API и метрики/health ---
SERVER_PORT=8080
PROMETHEUS_PORT=9090

# --- JWT (для API авторизации) ---
JWT_SECRET=change-me-in-production

# --- Локальный go run поверх make run-local-api (инфра в Docker на 127.0.0.1) ---
# Экспортируйте вручную или используйте второй файл:
#   set -a && source .env && source .env.local.api && set +a && go run ./cmd/bot/*.go
#
# DB_HOST_PORT=127.0.0.1:5432
# REDIS_ADDR=127.0.0.1:6379

# --- MinIO / S3 ---
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000/uploads

# --- File garbage collection ---
FILE_GC_ENABLED=true
FILE_GC_INTERVAL=1h
FILE_GC_ORPHAN_GRACE_PERIOD=24h
FILE_GC_DELETE_BATCH_SIZE=100

# Webserver
CADDY_LETSENCRYPT_EMAIL=email@for.letsencrypt
CADDY_DOMAIN_NAME=domain.for.letsencrypt

# --- Email ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USERNAME=sk.sillabus@mail.ru
SMTP_PASSWORD=
EMAIL_FROM=sk.sillabus@mail.ru
EMAIL_BASE_URL=https://razvitie.rassokha.pro