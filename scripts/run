#!/usr/bin/env bash
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"

MODE="${1:-local}"

case "$MODE" in
  local|full)
    exec make run-local
    ;;
  local-api|infra)
    exec make run-local-api
    ;;
  *)
    echo "Использование: $0 [local|local-api]"
    echo "  local (по умолчанию) — make run-local (инфра + app в Docker, порты на 127.0.0.1)"
    echo "  local-api          — make run-local-api (только Postgres и Redis)"
    exit 1
    ;;
esac
